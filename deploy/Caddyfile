{
	admin off
	email {$ACME_EMAIL}
	skip_install_trust
}

(security_headers) {
	header {
		-Server
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
	}
}

# Container-local liveness listener. It is bound to loopback and never exposed.
http://127.0.0.1:2019 {
	respond /healthz "OK" 200
}

{$PUBLIC_GAME_HOST} {
	import security_headers

	header Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' https://{$PUBLIC_SERVER_HOST} wss://{$PUBLIC_SERVER_HOST}; font-src 'self' data:; media-src 'self' data: blob:; worker-src 'self' blob:; frame-src 'none'; form-action 'self'; frame-ancestors 'none'"
	encode zstd gzip
	reverse_proxy client:8080
}

{$PUBLIC_SERVER_HOST} {
	import security_headers

	# Vanilla Caddy has no core rate-limit directive. Do not add a no-op stanza:
	# enforce request throttling at a trusted upstream edge or use a pinned,
	# separately audited Caddy build with a rate-limit module.
	@private_metrics path /metrics /metrics/*
	handle @private_metrics {
		respond 404
	}
	handle {
		header Cache-Control "no-store"
		reverse_proxy server:2567
	}
}
