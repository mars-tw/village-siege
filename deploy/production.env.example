# Public values only. Keep the two referenced password files outside the repository.
NODE_VERSION=24.15.0
VILLAGE_SIEGE_TAG=production
GIT_COMMIT_SHA=replace-with-full-git-commit-sha

# Hostnames only: no scheme, port, path, query, fragment, or credentials.
PUBLIC_GAME_HOST=play.example.com
PUBLIC_SERVER_HOST=server.play.example.com
ACME_EMAIL=operator@example.com

POSTGRES_DB=village_siege
POSTGRES_USER=village_siege
# The Redis secret must be 32-128 base64url characters: A-Z, a-z, 0-9, _ or -.
# Both password files must contain only the password plus an optional final newline.
REDIS_PASSWORD_FILE=/etc/village-siege/secrets/redis_password
POSTGRES_PASSWORD_FILE=/etc/village-siege/secrets/postgres_password
