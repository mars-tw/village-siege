# Local Compose only. Copy to .env, then replace both example passwords.
NODE_VERSION=24.15.0
VILLAGE_SIEGE_TAG=local
NODE_ENV=development
SERVER_BIND_ADDRESS=127.0.0.1
SERVER_PORT=2567
CLIENT_BIND_ADDRESS=127.0.0.1
CLIENT_PORT=8080
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
POSTGRES_DB=village_siege
POSTGRES_USER=village_siege
POSTGRES_PASSWORD=replace-with-a-long-random-postgres-password
REDIS_PASSWORD=replace-with-a-long-random-redis-password

# The local container serves single-player until a real HTTPS/WSS endpoint is supplied.
VITE_MULTIPLAYER_ENABLED=false
VITE_COLYSEUS_URL=
VITE_BASE_URL=/
PUBLIC_CONNECT_ORIGIN=
GIT_COMMIT_SHA=unknown
