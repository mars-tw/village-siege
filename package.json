{
  "name": "village-siege",
  "version": "0.3.0",
  "private": true,
  "license": "MIT",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "npm run dev:client",
    "dev:client": "npm run dev --workspace @village-siege/client",
    "dev:server": "npm run dev --workspace @village-siege/server",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "verify": "npm run typecheck && npm test && npm run build",
    "start:server": "npm run start --workspace @village-siege/server",
    "smoke:multiplayer": "node scripts/multiplayer-smoke.mjs",
    "smoke:multiplayer:local": "npm run build --workspace @village-siege/server && node scripts/multiplayer-smoke-local.mjs"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
